<mujocoinclude>
    <!-- L6Y arm meshes -->
    <mesh name="arm_base_link" file="arm_base_link.STL"/>
    <mesh name="arm_link_1" file="arm_link_1.STL"/>
    <mesh name="arm_link_2" file="arm_link_2.STL"/>
    <mesh name="arm_link_3" file="arm_link_3.STL"/>
    <mesh name="arm_link_4" file="arm_link_4.STL"/>
    <mesh name="arm_link_5" file="arm_link_5.STL"/>
    <mesh name="arm_link_6" file="arm_link_6.STL"/>

    <!-- GP100 gripper meshes (mapping from l6y_gp100.urdf) -->
    <mesh name="gripper_base_link" file="gripper_base_link.STL"/>
    <mesh name="camera_link" file="camera_link.STL"/>
    <!-- left helper uses link_1.STL -->
    <mesh name="gripper_left_helper_link" file="gp100_link_1.STL"/>
    <!-- left link 1 uses link_2.STL -->
    <mesh name="gripper_left_link_1" file="gp100_link_2.STL"/>
    <!-- left link 2 uses link_3.STL -->
    <mesh name="gripper_left_link_2" file="gp100_link_3.STL"/>
    <!-- right helper uses link_4.STL -->
    <mesh name="gripper_right_helper_link" file="gp100_link_4.STL"/>
    <!-- right link 1 uses link_5.STL -->
    <mesh name="gripper_right_link_1" file="gp100_link_5.STL"/>
    <!-- right link 2 uses link_6.STL -->
    <mesh name="gripper_right_link_2" file="gp100_link_6.STL"/>

    <!-- table -->
    <mesh name="table_link" file="table_link.STL" scale="0.001 0.001 0.001"/>

    <!-- Scanned objects (Google Scanned Objects dataset) -->
    <!-- Wooden ABC block (3.1x3.1x3.0cm) -->
    <mesh name="scanned_block_visual" file="scanned_block/model.obj"/>
    <texture name="scanned_block_tex" type="2d" file="scanned_block/texture.png"/>
    <material name="scanned_block_mat" texture="scanned_block_tex" specular="0.5" shininess="0.5"/>

    <!-- Toy dog (3.5x4.8x5.0cm) -->
    <mesh name="scanned_dog_visual" file="scanned_dog/model.obj"/>
    <texture name="scanned_dog_tex" type="2d" file="scanned_dog/texture.png"/>
    <material name="scanned_dog_mat" texture="scanned_dog_tex" specular="0.5" shininess="0.5"/>

    <!-- Kong puppy rubber toy (4.5x4.4x7.2cm) -->
    <mesh name="scanned_kong_visual" file="scanned_kong/model.obj"/>
    <texture name="scanned_kong_tex" type="2d" file="scanned_kong/texture.png"/>
    <material name="scanned_kong_mat" texture="scanned_kong_tex" specular="0.5" shininess="0.5"/>

    <!-- Android panda figure (6.1x4.6x7.6cm) -->
    <mesh name="scanned_panda_visual" file="scanned_panda/model.obj"/>
    <texture name="scanned_panda_tex" type="2d" file="scanned_panda/texture.png"/>
    <material name="scanned_panda_mat" texture="scanned_panda_tex" specular="0.5" shininess="0.5"/>
</mujocoinclude>
