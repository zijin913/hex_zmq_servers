                                    <!-- Tianyi 总装 gripper: body (Link_1) + 2 claws. Mount = Rz(+90deg)
                                         about the wrist axis to match the soda-ui (three.js) render. MuJoCo
                                         renders meshes through their mesh_quat while three.js renders them
                                         as-is, so this +90deg aligns the sim gripper with the UI orientation.
                                         Claws axis 0 0 -1; right mimics left (multiplier -1, setting_dual.xml). -->
                                    <body name="right_gripper_mount" pos="0 0 0" quat="0.7071068 0 0 0.7071068">
                                        <inertial pos="0 0.00524 0.04602" mass="0.47163661" diaginertia="0.00032421 0.00032388 0.00022576"/>
