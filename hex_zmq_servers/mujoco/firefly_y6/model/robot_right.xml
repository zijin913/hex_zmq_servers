                                <!-- Gripper base frame = link_6 (identity). Kept un-rotated so the wrist
                                     camera + ee_frame (calibrated to link_6) are unaffected. The Tianyi 总装
                                     gripper body + claws hang off a child mount rotated rpy(0,0,-90deg). -->
                                <body name="right_gripper_base_link" pos="0 0 0" quat="1 0 0 0">
                                    <inertial pos="0 0 0.02" mass="0.0001" diaginertia="1e-7 1e-7 1e-7"/>

                                    <!-- Wrist camera + visual mesh — derived from real hand-eye calibration
                                         (hand_eye_calibration/results/dual/right_hand.json, T_cam2gripper).
